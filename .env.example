NODE_ENV=development
PORT=3000
LOG_LEVEL=info
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=telemetry.exchange
RABBITMQ_ROUTING_KEY=telemetry.ingest
RABBITMQ_QUEUE=telemetry.ingest.queue
RABBITMQ_DLX=telemetry.dlx
RABBITMQ_DLQ=telemetry.dead.queue
RABBITMQ_PREFETCH=100
DATABASE_URL=postgres://postgres:postgres@postgres:5432/telemetry
MAX_RETRY_ATTEMPTS=30
RETRY_DELAY_MS=2000